{
    "name": "poetry-for-neanderthals",
    "private": true,
    "scripts": {
        "build": "ng build --verbose",
        "build:dev": "ng build --verbose --watch --configuration dev",
        "knip": "knip",
        "lint": "ng lint --fix --max-warnings=0",
        "prepare": "husky && sort-package-json",
        "prettier": "prettier --write .",
        "start": "ng serve"
    },
    "lint-staged": {
        "*": [
            "eslint --fix --max-warnings=0 --no-warn-ignored",
            "prettier --write --ignore-unknown"
        ]
    },
    "dependencies": {
        "@angular/common": "^21.2.16",
        "@angular/compiler": "^21.2.16",
        "@angular/core": "^21.2.16",
        "@angular/forms": "^21.2.16",
        "@angular/platform-browser": "^21.2.16",
        "@angular/router": "^21.2.16",
        "bootstrap": "^5.3.8",
        "bootstrap-icons": "^1.13.1",
        "crypto-js": "^4.2.0",
        "lodash": "^4.18.1",
        "ngx-logger": "^5.0.12",
        "rxjs": "~7.8.2",
        "seedrandom": "^3.0.5",
        "sort-package-json": "^3.7.0",
        "tslib": "^2.8.1",
        "uuid": "^14.0.0",
        "zone.js": "~0.16.2"
    },
    "devDependencies": {
        "@angular-eslint/builder": "^21.4.0",
        "@angular/build": "^21.2.14",
        "@angular/cli": "^21.2.14",
        "@angular/compiler-cli": "^21.2.16",
        "@eslint/css": "^1.3.0",
        "@eslint/js": "^10.0.1",
        "@types/bootstrap": "^5.2.11",
        "@types/crypto-js": "^4.2.2",
        "@types/lodash": "^4.17.24",
        "@types/seedrandom": "^3.0.8",
        "angular-eslint": "21.4.0",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "knip": "^5.88.1",
        "lint-staged": "^16.4.0",
        "npm-check-updates": "^19.6.6",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "8.60.1"
    }
}
